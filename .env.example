# PostgreSQL (local Docker)
DATABASE_URL=postgresql://grid_resilience:grid_resilience@localhost:5432/grid_resilience
PG_CONNECTION_STRING=postgresql://grid_resilience:grid_resilience@localhost:5432/grid_resilience

# MinIO (local Docker) — required for pipeline runs
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=grid-resilience

# --- Data source API keys (for fetch scripts, not committed) ---
# ERA5 (CDS): get key at https://cds.climate.copernicus.eu/profile (Register → API key).
# Either set these OR use a .cdsapirc file in repo root or ~ (see data-engineering/README.md).
# CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
# CDSAPI_KEY=YOUR_UID:YOUR_API_KEY

# ENTSO-E (optional, for grid/load data): token from https://transparency.entsoe.eu/
# ENTSOE_TOKEN=
